# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database
SUPABASE_DB_URL=postgresql://username:password@host:port/database

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here

# Environment
NODE_ENV=production

# Optional: Email Configuration (for account creation and notifications)
# For Gmail: Use App Password (not regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM_NAME=CVZen
SMTP_FROM_EMAIL=your-email@gmail.com

# SMTP2GO Email Service Configuration
SMTP2GO_API_KEY=api-46E3A066DD694FDA839FA5DD4763F7A6
FROM_EMAIL=cvzen@cvzen.ai
FROM_NAME=CVZen

# Optional: File Upload Configuration
UPLOAD_MAX_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Payment Gateway Configuration
PAYMENT_GATEWAY=phonepe
# PAYMENT_GATEWAY=razorpay
# PAYMENT_GATEWAY=stripe

# PhonePe Configuration
PHONEPE_MERCHANT_ID=your-merchant-id
PHONEPE_SALT_KEY=your-salt-key
PHONEPE_SALT_INDEX=1
PHONEPE_API_ENDPOINT=https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_REDIRECT_URL=https://yourdomain.com/payment/success
PHONEPE_CALLBACK_URL=https://yourdomain.com/api/payment/callback

# Razorpay Configuration
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

APP_URL=https://yourdomain.com

# Optional: Override client URL for job posting links (defaults to APP_URL)
# CLIENT_URL=https://yourclientdomain.com

# Tavily API Configuration (for website crawling)
TAVILY_API_KEY=your-tavily-api-key

# AI Service Configuration - Choose between GROQ or OPENAI
AI_SERVICE=GROQ

# OpenAI Configuration (for AI-powered features - Premium)
# Replace with your actual OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-actual-openai-api-key-here

# Groq API Configuration (for AI-powered features)
GROQ_API_KEY=your-groq-api-key