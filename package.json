{
  "name": "fusion-starter",
  "private": true,
  "type": "module",
  "pkg": {
    "assets": [
      "dist/spa/*"
    ],
    "scripts": [
      "dist/server/**/*.js"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx server/standalone.ts",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "build": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\" && npm run build:server && npm run build:client",
    "build:client": "vite build --mode production",
    "build:server": "vite build --config vite.config.server.ts",
    "start": "node -r dotenv/config dist/server/node-build.mjs",
    "test": "vitest --run",
    "format.fix": "prettier --write .",
    "typecheck": "tsc",
    "content:create": "tsx client/tools/contentManagementCLI.ts create",
    "content:validate": "tsx client/tools/contentManagementCLI.ts validate",
    "content:submit": "tsx client/tools/contentManagementCLI.ts submit",
    "content:review": "tsx client/tools/contentManagementCLI.ts review",
    "content:list-reviews": "tsx client/tools/contentManagementCLI.ts list-reviews",
    "content:history": "tsx client/tools/contentManagementCLI.ts history",
    "content:rollback": "tsx client/tools/contentManagementCLI.ts rollback",
    "content:export": "tsx client/tools/contentManagementCLI.ts export",
    "content:import": "tsx client/tools/contentManagementCLI.ts import",
    "content:help": "tsx client/tools/contentManagementCLI.ts help"
  },
  "dependencies": {
    "@ax-llm/ax": "^18.0.13",
    "@e2b/code-interpreter": "^1.5.1",
    "@langchain/community": "^1.1.10",
