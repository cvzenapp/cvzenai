    "@livekit/components-styles": "^1.2.0",
    "@react-pdf/renderer": "^4.3.0",
    "@reduxjs/toolkit": "^2.9.0",
    "@supabase/supabase-js": "^2.56.0",
    "@tavily/core": "^0.7.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/sqlite3": "^3.1.11",
    "@types/stripe": "^8.0.416",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
