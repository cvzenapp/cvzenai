# Server Configuration
NODE_ENV=development
PORT=4000
HOST=localhost

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/interview_system
DB_HOST=localhost
DB_PORT=5432
DB_NAME=interview_system
DB_USER=postgres
DB_PASSWORD=password
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Configuration (Must match CVZen)
JWT_SECRET=cvzen_jwt_secret_key_2024_secure_token_signing
JWT_EXPIRES_IN=24h

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,mp4,webm,wav,mp3

# Recording Configuration
RECORDING_ENABLED=true
RECORDING_QUALITY=high
MAX_RECORDING_DURATION=7200
RECORDING_FORMAT=webm

# WebRTC Configuration
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_SERVER_URL=
TURN_USERNAME=
TURN_PASSWORD=

# CVZen Integration
CVZEN_API_URL=http://localhost:3001/api
CVZEN_WEBHOOK_SECRET=webhook_secret_key
CVZEN_BASE_URL=http://localhost:8080

# Security
CORS_ORIGIN=http://localhost:8080,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/interview-system.log

# Redis (Optional - for session management)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Monitoring
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true